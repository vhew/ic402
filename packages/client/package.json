{
  "name": "@ic402/client",
  "version": "0.1.2",
  "description": "TypeScript client SDK for ic402-enabled ICP canisters",
  "license": "Apache-2.0",
  "author": "ic402 contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/vhew/ic402.git",
    "directory": "packages/client"
  },
  "keywords": [
    "ic402",
    "x402",
    "payment",
    "icp",
    "internet-computer",
    "typescript",
    "sdk",
    "evm",
    "icrc2",
    "micropayment",
    "streaming",
    "eip-3009"
  ],
  "type": "module",
  "main": "dist/index.js",
