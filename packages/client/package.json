  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=19.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@canister-software/x402-icp": "0.1.1",
    "@x402/core": "2.7.0",
    "@x402/fetch": "2.7.0",
    "cborg": "4.5.8",
    "viem": "2.47.5"
  },
  "peerDependencies": {
    "@icp-sdk/core": ">=5.1.0"
  },
  "devDependencies": {
    "@icp-sdk/core": "5.1.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
