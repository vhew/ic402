# ic402 environment variables
# Copy to .env.development (gitignored) and fill in values.
#
# Used by: pnpm demo, deploy/deploy.sh, pnpm register-agent

# ── Avalanche Fuji testnet ──

# Private key for an Avalanche Fuji wallet (for gas fees).
# Generate one: cast wallet new
# Fund it: https://faucet.avax.network (paste the address, get 2 AVAX)
# NEVER commit the real value.
export AVAX_PRIVATE_KEY=""

# IdentityRegistry contract address on Fuji.
# Leave blank to deploy a new contract; set to reuse an existing one.
export AVAX_REGISTRY_CONTRACT="0x0F3998E6E4287fa7a5620979c5513D8e83fE80D3"

# Avalanche RPC endpoint (default: Fuji public RPC)
export AVAX_RPC="https://api.avax-test.network/ext/bc/C/rpc"

# tECDSA key name ("dfx_test_key" for local replica, "key_1" for mainnet IC)
export ECDSA_KEY_NAME="dfx_test_key"
