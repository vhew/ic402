# ic402 Local Development Environment
# Copy to .env.development and fill in values.
# Used by: pnpm setup, pnpm demo, scripts/setup.sh, scripts/register-agent.ts
#
# For production deployment, see deploy/.env.production.example

# ── ICP ──

# tECDSA key name (local replica)
export ECDSA_KEY_NAME="dfx_test_key"

# ICP principal of the local-dev identity (auto-detected if blank)
export DEPLOY_PRINCIPAL=""

# ── Base Sepolia (ERC-8004 identity registration, optional) ──

# Private key for a Base Sepolia wallet (for gas fees).
# Generate:  cast wallet new
# Fund:      https://portal.cdp.coinbase.com/products/faucet (select Base Sepolia)
# NEVER commit the real value.
export BASE_PRIVATE_KEY=""

# IdentityRegistry contract address on Base Sepolia.
# Leave blank to deploy a new contract on first run.
export BASE_REGISTRY_CONTRACT=""

# Base Sepolia RPC endpoint
export BASE_RPC="https://sepolia.base.org"
