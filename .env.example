# ic402 environment variables
# Copy to .env.development (gitignored) and fill in values.
#
# Used by: pnpm demo, pnpm register-agent

# ── Base Sepolia testnet (identity registration) ──

# Private key for a Base Sepolia wallet (for gas fees).
# Generate one: cast wallet new
# Fund it: bridge Sepolia ETH to Base Sepolia, or use a faucet
# NEVER commit the real value.
export BASE_PRIVATE_KEY=""

# IdentityRegistry contract address on Base Sepolia.
# Leave blank to deploy a new contract; set to reuse an existing one.
export BASE_REGISTRY_CONTRACT=""

# Base Sepolia RPC endpoint
export BASE_RPC="https://sepolia.base.org"

# tECDSA key name ("dfx_test_key" for local replica, "key_1" for mainnet IC)
export ECDSA_KEY_NAME="dfx_test_key"
